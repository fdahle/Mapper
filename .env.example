# Secret used to sign JWT tokens. Must be at least 32 characters.
SESSION_SECRET=replace-with-a-long-random-string-at-least-32-chars

# Port the API server listens on (default: 3000)
PORT=3000

# Set to "production" in production environments.
# Affects: cookie Secure flag, error log verbosity (stack traces suppressed in production).
NODE_ENV=production
